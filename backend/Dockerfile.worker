FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Celery worker — uses -P solo to avoid fork issues in containerized envs
CMD ["celery", "-A", "app.core.celery_app", "worker", "--loglevel=info", "-Q", "campaigns", "-P", "solo", "--concurrency=1"]
